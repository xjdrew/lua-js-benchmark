root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{sh,bash}]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[*.{lua,js}]
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{html,css}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
